# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# SMTP Email (e.g. Gmail, SendGrid, Mailgun, AWS SES)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# AR Team CC email (gets CC'd on every payment link email)
AR_CC_EMAIL=ar-team@yourcompany.com

# Your company name (shown in emails)
COMPANY_NAME=Your Company

# Default redirect URL after payment completion
NEXT_PUBLIC_DEFAULT_REDIRECT_URL=https://yourcompany.com/payment-success
