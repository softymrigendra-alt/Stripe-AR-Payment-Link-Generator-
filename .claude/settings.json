{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Read(//usr/local/bin/**)",
      "Read(//opt/homebrew/bin/**)",
      "Bash(command -v node)",
      "Bash(export PATH=\"/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH\")",
      "Bash(npm --version)",
      "Bash(echo \"PATH=$PATH\")",
      "Bash(git --version)",
      "Bash(ngrok config:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)"
    ]
  }
}
